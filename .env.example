# PostgreSQL direct connection (same as fullstack)
POSTGRES_URL=postgresql://postgres:PASSWORD@db.SUPABASEID.supabase.co:5432/postgres

# Supabase REST API (for storage + rpc tools)
SUPABASE_URL=https://SUPABASEID.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Iceberg / Data Lake (for query_iceberg tool)
CATALOG_URI=https://...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_ENDPOINT=https://...
ICEBERG_WAREHOUSE=nla-audit-lake
ICEBERG_NAMESPACE=audit
ICEBERG_TOKEN=same-as-secret-sb-key
